---
export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  jsonLd?: object;
}

const {
  title,
  description = '衝浪研究室 — 八份田野檔案,一本非旅遊指南。Bali 50 · 海南 21 · 澳洲 42 · 台灣 33 · 日本 27 · 韓國 22 · 小浪板 33 · 大浪板 29 = 257 entries。',
  canonical,
  ogImage,
  jsonLd
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || '';
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).toString();
const finalOgImage = ogImage || new URL('/og-default.png', siteUrl || 'https://surf-study.jkjking987.workers.dev').toString();

const defaultJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: '衝浪研究室 · The Surf Study',
  alternateName: 'The Surf Study',
  url: siteUrl || 'https://surf-study.jkjking987.workers.dev',
  description,
  inLanguage: 'zh-Hant',
  publisher: {
    '@type': 'Organization',
    name: '衝浪研究室 · The Surf Study'
  }
};
const finalJsonLd = jsonLd ?? defaultJsonLd;
---

<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="zh_TW" />
  <meta property="og:image" content={finalOgImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={finalOgImage} />

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(finalJsonLd)} />

  <!-- Styles -->
  <link rel="stylesheet" href="/styles/tokens.css" />
  <link rel="stylesheet" href="/styles/common.css" />
  <link rel="stylesheet" href="/styles/motion.css" />

  <slot name="head" />
</head>
<body>
  <slot />

  <!-- Tweaks FAB -->
  <button id="tweaks-fab" title="Tweaks · 主題與顯示">TWEAKS</button>

  <!-- Common JS: Theme, Favorites, Global Search, Keyboard Shortcuts -->
  <script is:inline src="/scripts/common.js"></script>
  <!-- Motion: scroll-reveal cascade, ticker loop -->
  <script is:inline src="/scripts/motion.js"></script>
</body>
</html>
