<script is:inline>
  // ===== Hero: tap to cycle tricks + ambient parallax + live clock =====
  (function hero(){
    const hero = document.getElementById('hero');
    const labelWrap = document.getElementById('trick');
    const label = document.getElementById('trickName');
    if(!hero) return;
    const tricks = ['CUT BACK', 'TOP TURN', '360° AIR', 'BARREL', 'OFF THE LIP'];
    let i = 0;
    function cycle(){
      labelWrap.classList.add('flip');
      setTimeout(() => {
        i = (i + 1) % tricks.length;
        label.textContent = tricks[i];
        labelWrap.classList.remove('flip');
      }, 220);
    }
    hero.addEventListener('click', cycle);

    let t = 0;
    setInterval(() => {
      t += 0.05;
      const mx = Math.sin(t * 0.6) * 0.4;
      hero.style.setProperty('--mx', mx.toFixed(3));
    }, 80);

    const time = document.getElementById('hTime');
    function tick(){
      const d = new Date();
      let h = d.getHours(), m = d.getMinutes();
      const ap = h >= 12 ? 'PM' : 'AM';
      h = h % 12 || 12;
      time.textContent = String(h).padStart(2,'0') + ':' + String(m).padStart(2,'0') + ' ' + ap;
    }
    tick();
    setInterval(tick, 30000);
  })();

  // ===== Magazine rack: dot indicators =====
  (function rack(){
    const rack = document.getElementById('rack');
    const dotsEl = document.getElementById('rackDots');
    if(!rack || !dotsEl) return;
    const dots = Array.from(dotsEl.children);
    const cards = rack.querySelectorAll('.rack-card');
    rack.addEventListener('scroll', () => {
      const w = rack.scrollLeft + rack.clientWidth / 2;
      let idx = 0;
      cards.forEach((c, n) => { if (c.offsetLeft <= w) idx = n; });
      dots.forEach((d, n) => d.classList.toggle('on', n === idx));
    }, { passive: true });
  })();

  // ===== Bottom tab bar: route to section or open sheet =====
  (function tabs(){
    const tabs = document.querySelectorAll('.tabbar .tab');
    tabs.forEach(t => t.addEventListener('click', () => {
      tabs.forEach(x => x.classList.remove('active'));
      t.classList.add('active');
      const id = t.dataset.tab;
      if (id === 'search') { openSheet('m-search'); return; }
      if (id === 'library'){ openSheet('m-library'); return; }
      const map = { issues: '.featured-wrap', tools: '.tools-section' };
      const target = document.querySelector(map[id] || '.masthead');
      if (target) {
        const top = target.getBoundingClientRect().top + window.scrollY - 80;
        window.scrollTo({ top, behavior: 'smooth' });
      }
    }));
  })();

  // ===== Scroll progress under topbar =====
  (function prog(){
    const p = document.getElementById('scrollProg');
    if(!p) return;
    window.addEventListener('scroll', () => {
      const h = document.documentElement.scrollHeight - window.innerHeight;
      const pct = Math.min(100, Math.max(0, (window.scrollY / h) * 100));
      p.style.width = pct + '%';
    }, { passive: true });
  })();

  // ===== Sheets: open / close + Esc handler =====
  function openSheet(id){
    const sheet = document.getElementById(id);
    const bd = document.getElementById('sheet-backdrop');
    document.querySelectorAll('.sheet.open').forEach(s => {
      s.classList.remove('open');
      s.setAttribute('aria-hidden','true');
    });
    sheet.classList.add('open');
    sheet.setAttribute('aria-hidden','false');
    bd.classList.add('open');
    document.body.style.overflow = 'hidden';
    // Autofocus search input
    if(id === 'm-search'){
      setTimeout(() => document.getElementById('m-search-in')?.focus(), 50);
    }
  }
  function closeSheets(){
    document.querySelectorAll('.sheet.open').forEach(s => {
      s.classList.remove('open');
      s.setAttribute('aria-hidden','true');
    });
    document.getElementById('sheet-backdrop').classList.remove('open');
    document.body.style.overflow = '';
  }
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closeSheets();
  });
  window.openSheet = openSheet;
  window.closeSheets = closeSheets;

  // ===== Hydrate library sheet from localStorage favorites (shared with desktop) =====
  (function hydrateLibrary(){
    const list = document.getElementById('m-fav-list');
    const dot = document.querySelector('.tab[data-tab="library"] .badge-dot');
    const navStar = document.querySelectorAll('.icon-btn')[1];
    let favs = {};
    try { favs = JSON.parse(localStorage.getItem('surf-study.favs.v1') || '{}'); } catch(e) {}
    const keys = Object.keys(favs);
    // Topbar star badge
    if(navStar && keys.length > 0){
      const badge = document.createElement('span');
      badge.className = 'dot';
      badge.textContent = String(keys.length);
      navStar.appendChild(badge);
    }
    // Tab star dot only when there are favs
    if(dot && keys.length === 0) dot.style.display = 'none';
    // Library sheet list
    if(!list || keys.length === 0) return;
    list.innerHTML = keys.map(k => {
      const [issue, slug] = k.split('/');
      return '<a class="sheet-link" href="/' + issue + '/' + slug + '">'
        + '<span class="ix">' + issue.toUpperCase().slice(0,3) + '</span>'
        + '<span class="name">' + slug.replace(/-/g, ' ') + '<small>' + issue + '</small></span>'
        + '<span class="arrow">→</span></a>';
    }).join('');
  })();

  // ===== Remember desktop preference =====
  // If user clicks "桌面版 →", set sessionStorage so the index.astro redirect skips
  document.getElementById('desktop-link')?.addEventListener('click', () => {
    try { sessionStorage.setItem('desktop', '1'); } catch(e) {}
  });
</script>

