---
const title = '衝浪研究室 · Mobile Edition';
const description = '衝浪研究室 — 八份田野檔案,一本非旅遊指南。Bali 50 · 海南 21 · 澳洲 42 · 台灣 33 · 日本 27 · 韓國 22 · 小浪板 33 · 大浪板 29 = 257 entries。';
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://surf-study.jkjking987.workers.dev';
const canonicalUrl = new URL('/mobile', siteUrl).toString();
const ogImage = new URL('/og-default.png', siteUrl).toString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: '衝浪研究室 · The Surf Study',
  alternateName: 'The Surf Study',
  url: siteUrl,
  description,
  inLanguage: 'zh-Hant'
};
---

<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="zh_TW" />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <link rel="stylesheet" href="/styles/tokens.css" />

  <style>
    /* =========================================================
       MOBILE EDITION — purpose-built mobile homepage
       390px design width, full-bleed on touch devices
       ========================================================= */
    html, body { margin: 0; padding: 0; background: var(--paper); }
    body {
      font-family: var(--sans);
      color: var(--ink);
      -webkit-font-smoothing: antialiased;
      overscroll-behavior-y: none;
    }
    body::before { opacity: .14; }

    .app {
      display: flex;
      flex-direction: column;
      min-height: 100vh;
      background: var(--paper);
    }

    /* ============ STICKY TOP CHROME ============ */
    .topbar {
      position: sticky;
      top: 0;
      z-index: 20;
      background: var(--paper);
      border-bottom: 1.5px solid var(--ink);
    }
    .nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 8px 12px 7px;
      gap: 8px;
      background: var(--paper);
    }
    .nav-left { display: flex; align-items: center; gap: 8px; min-width: 0; }
    .nav-logo {
      font-family: var(--serif);
      font-weight: 900;
      font-size: 14px;
      letter-spacing: .18em;
      line-height: 1;
      white-space: nowrap;
    }
    .nav-no {
      font-family: var(--mono);
      font-size: 9.5px;
      letter-spacing: .12em;
      background: var(--ink);
      color: var(--paper);
      padding: 3px 6px 2px;
      line-height: 1;
    }
    .nav-icons { display: flex; gap: 4px; }
    .icon-btn {
      width: 44px;
      height: 44px;
      border: 1.4px solid var(--ink);
      background: var(--paper);
      color: var(--ink);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-family: var(--mono);
      font-size: 15px;
      cursor: pointer;
      padding: 0;
      position: relative;
    }
    .icon-btn:active { background: var(--ink); color: var(--paper); }
    .icon-btn .dot {
      position: absolute;
      top: -3px; right: -3px;
      background: var(--vermillion);
      color: var(--paper);
      font-size: 8.5px;
      min-width: 14px;
      height: 14px;
      border-radius: 8px;
      border: 1.2px solid var(--ink);
      padding: 0 3px;
      line-height: 11px;
      text-align: center;
      font-family: var(--mono);
    }

    .ticker-strip {
      display: flex;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      gap: 18px;
      padding: 6px 14px;
      background: var(--ink);
      color: var(--paper);
      font-family: var(--mono);
      font-size: 9.5px;
      letter-spacing: .14em;
      text-transform: uppercase;
      white-space: nowrap;
      align-items: center;
    }
    .ticker-strip::-webkit-scrollbar { display: none; }
    .ticker-strip .live {
      color: var(--vermillion);
      font-size: 11px;
      line-height: 1;
      animation: blink 1.4s steps(2, end) infinite;
    }
    @keyframes blink { 50% { opacity: .3; } }
    .ticker-strip .sep { color: oklch(0.7 0.03 60 / .5); }

    .scroll-prog {
      position: absolute;
      left: 0; bottom: -1.5px;
      height: 2px;
      background: var(--vermillion);
      width: 0%;
      transition: width .1s;
    }

    /* ============ MASTHEAD ============ */
    .masthead {
      padding: 22px 18px 18px;
      border-bottom: 4px double var(--ink);
      background: var(--paper);
      text-align: center;
      position: relative;
    }
    .eyebrow-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-family: var(--mono);
      font-size: 9px;
      letter-spacing: .16em;
      text-transform: uppercase;
      color: var(--ink-soft);
      margin-bottom: 14px;
    }
    .eyebrow-row .verm { color: var(--vermillion-d); font-weight: 700; }
    .masthead h1 {
      font-family: var(--display);
      font-size: clamp(54px, 17vw, 72px);
      line-height: .9;
      margin: 0;
      letter-spacing: -.015em;
      color: var(--ink);
      text-align: left;
      padding-right: 4px;
    }
    .masthead h1 .word { display: block; }
    .masthead h1 .word:nth-child(2) { text-align: right; }
    .masthead h1 em {
      font-family: var(--display-2);
      font-style: italic;
      font-weight: 400;
      color: var(--vermillion);
      font-size: .82em;
    }
    .ch-caption {
      margin-top: 12px;
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      font-family: var(--serif);
      font-weight: 900;
      font-size: 12px;
      letter-spacing: .22em;
      padding-left: .22em;
      white-space: nowrap;
      word-break: keep-all;
    }
    .ch-caption .corner {
      font-family: var(--mono);
      font-weight: 500;
      font-size: 9px;
      letter-spacing: .14em;
      color: var(--ink-soft);
    }

    /* ============ HERO SCENE ============ */
    .hero {
      position: relative;
      height: 200px;
      overflow: hidden;
      border-bottom: 1.5px solid var(--ink);
      background: linear-gradient(180deg,
        oklch(0.84 0.08 65) 0%,
        oklch(0.74 0.13 45) 30%,
        oklch(0.50 0.13 230) 62%,
        oklch(0.32 0.10 235) 100%);
      cursor: pointer;
      user-select: none;
      --mx: 0;
    }
    .hero .sun {
      position: absolute;
      top: 14%; left: 50%;
      transform: translate(calc(-50% + var(--mx) * -16px), 0);
      width: 78px; height: 78px;
      border-radius: 50%;
      background: radial-gradient(circle,
        oklch(0.96 0.05 80) 0%,
        oklch(0.92 0.12 70) 38%,
        oklch(0.78 0.18 50) 62%,
        transparent 78%);
      animation: pulse 5s ease-in-out infinite;
    }
    @keyframes pulse { 50% { filter: brightness(1.1); } }
    .hero .horizon {
      position: absolute;
      left: 0; right: 0;
      bottom: 48%;
      height: 1px;
      background: oklch(0.85 0.06 220 / .55);
      box-shadow: 0 0 6px oklch(0.92 0.10 60 / .55);
    }
    .hero .headland {
      position: absolute;
      bottom: 48%;
      left: -6%;
      width: 38%;
      height: 12%;
      background: oklch(0.22 0.05 245 / .85);
      clip-path: polygon(0 100%, 8% 60%, 22% 78%, 38% 30%, 56% 65%, 72% 50%, 88% 70%, 100% 95%, 100% 100%);
    }
    .hero .wave-back {
      position: absolute;
      left: 0; right: 0;
      bottom: 38%;
      height: 14%;
      background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 600 80' preserveAspectRatio='none'><path d='M 0 40 Q 150 0 300 40 Q 450 80 600 40 L 600 80 L 0 80 Z' fill='%232c6694'/></svg>");
      background-repeat: repeat-x;
      background-size: 320px 100%;
      animation: scroll-back 22s linear infinite;
      opacity: .82;
    }
    .hero .wave-mid {
      position: absolute;
      left: 0; right: 0;
      bottom: 22%;
      height: 24%;
      background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 700 120' preserveAspectRatio='none'><path d='M 0 70 Q 175 10 350 70 Q 525 130 700 70 L 700 120 L 0 120 Z' fill='%231b4a72'/></svg>");
      background-repeat: repeat-x;
      background-size: 380px 100%;
      animation: scroll-mid 14s linear infinite reverse;
    }
    @keyframes scroll-back { to { background-position-x: -320px; } }
    @keyframes scroll-mid  { to { background-position-x: -380px; } }
    .hero .wave-front { position: absolute; inset: auto 0 0 0; height: 56%; }
    .hero .wave-front svg { width: 100%; height: 100%; display: block; }
    .hero .surfer {
      position: absolute;
      bottom: 42%;
      left: 52%;
      width: 62px;
      height: 78px;
      transform: translateX(calc(-50% + var(--mx) * 40px)) rotate(12deg);
      transform-origin: 50% 75%;
      filter: drop-shadow(0 4px 6px rgba(26,22,20,.45));
    }
    .hero .surfer svg { width: 100%; height: 100%; }
    .hero .surfer .body {
      animation: surfer-rock 4s ease-in-out infinite;
      transform-origin: 50% 90%;
    }
    @keyframes surfer-rock {
      0%, 100% { transform: translateY(0) rotate(0); }
      50%      { transform: translateY(-2px) rotate(-4deg); }
    }
    .hero .splash {
      position: absolute;
      left: 50%; bottom: 36%;
      width: 80px; height: 30px;
      transform: translateX(-50%);
      pointer-events: none;
    }
    .hero .splash i {
      position: absolute;
      width: 2.5px; height: 2.5px;
      border-radius: 50%;
      background: oklch(0.97 0.02 220);
      opacity: 0;
      animation: splash 1.1s ease-out infinite;
    }
    .hero .splash i:nth-child(1) { left: 10%; animation-delay: 0s; }
    .hero .splash i:nth-child(2) { left: 30%; animation-delay: .2s; width: 3.2px; height: 3.2px; }
    .hero .splash i:nth-child(3) { left: 52%; animation-delay: .45s; }
    .hero .splash i:nth-child(4) { left: 74%; animation-delay: .7s; width: 3.6px; height: 3.6px; }
    .hero .splash i:nth-child(5) { left: 88%; animation-delay: .9s; }
    @keyframes splash {
      0%   { opacity: 0; transform: translateY(0) scale(.4); }
      20%  { opacity: .9; }
      100% { opacity: 0; transform: translateY(-22px) scale(1.2); }
    }
    .hero .grain {
      position: absolute;
      inset: 0;
      background-image: radial-gradient(rgba(26,22,20,.18) 1px, transparent 1.4px);
      background-size: 4px 4px;
      mix-blend-mode: multiply;
      opacity: .35;
      pointer-events: none;
    }
    .hero .trick {
      position: absolute;
      top: 12px; left: 14px;
      color: oklch(0.98 0.02 60);
      font-family: var(--mono);
      text-shadow: 0 1px 6px rgba(0,0,0,.7);
      z-index: 4;
      background: linear-gradient(180deg, rgba(0,0,0,.25), rgba(0,0,0,0));
      padding: 4px 8px 6px;
      margin: -4px 0 0 -4px;
      border-radius: 0 0 6px 0;
    }
    .hero .trick small {
      display: block;
      font-size: 8.5px;
      letter-spacing: .2em;
      text-transform: uppercase;
      opacity: .8;
      color: oklch(0.94 0.10 60);
      margin-bottom: 2px;
    }
    .hero .trick strong {
      font-family: var(--display);
      font-weight: 400;
      font-size: 22px;
      letter-spacing: .04em;
      line-height: 1;
      display: block;
      transition: opacity .22s, transform .3s;
    }
    .hero .trick.flip strong { opacity: 0; transform: translateY(-4px); }
    .hero .tap-hint {
      position: absolute;
      bottom: 10px; right: 12px;
      font-family: var(--mono);
      font-size: 9.5px;
      font-weight: 700;
      letter-spacing: .16em;
      text-transform: uppercase;
      color: oklch(0.18 0.02 30);
      z-index: 4;
      background: oklch(0.96 0.04 70);
      padding: 5px 9px 4px;
      border: 1.4px solid oklch(0.18 0.02 30);
      line-height: 1;
    }
    .hero .time {
      position: absolute;
      bottom: 8px; left: 14px;
      font-family: var(--mono);
      font-size: 8.5px;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: oklch(0.96 0.02 60 / .75);
      z-index: 4;
    }
    .hero .time .verm { color: oklch(0.78 0.18 50); }

    /* ============ EDITOR'S NOTE ============ */
    .editor-note {
      padding: 22px 18px 18px;
      background: var(--paper);
      border-bottom: 1.5px solid var(--ink);
    }
    .editor-note .label {
      font-family: var(--mono);
      font-size: 9.5px;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--vermillion-d);
      margin-bottom: 10px;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .editor-note .label::before {
      content: "";
      display: inline-block;
      width: 18px; height: 1.5px;
      background: var(--vermillion-d);
    }
    .editor-note h2 {
      font-family: var(--display-2);
      font-style: italic;
      font-weight: 400;
      font-size: 26px;
      line-height: 1.18;
      margin: 0 0 14px;
      color: var(--ocean);
      word-break: keep-all;
      text-wrap: pretty;
    }
    .editor-note h2 em { color: var(--vermillion); font-style: italic; }
    .editor-note p {
      font-family: var(--serif);
      font-size: 14.5px;
      line-height: 1.7;
      margin: 0;
      color: var(--ink);
      word-break: keep-all;
    }
    .editor-note p::first-letter {
      font-family: var(--display);
      font-size: 3em;
      float: left;
      line-height: .82;
      padding: 4px 8px 0 0;
      color: var(--vermillion);
    }
    .editor-note .more {
      display: inline-block;
      margin-top: 12px;
      font-family: var(--mono);
      font-size: 10.5px;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--ink);
      border-bottom: 1.5px solid var(--ink);
      padding-bottom: 1px;
      text-decoration: none;
    }

    /* ============ STATS 2×2 ============ */
    .stats {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      border-bottom: 1.5px solid var(--ink);
    }
    .stats .s {
      padding: 14px 16px 12px;
      border-right: 1.5px solid var(--ink);
      border-bottom: 1.5px solid var(--ink);
      background: var(--paper);
    }
    .stats .s:nth-child(2n) { border-right: 0; }
    .stats .s:nth-last-child(-n+2) { border-bottom: 0; }
    .stats .n {
      font-family: var(--display);
      font-size: 36px;
      line-height: .9;
      color: var(--vermillion);
      overflow-wrap: anywhere;
      display: flex;
      align-items: baseline;
      gap: 3px;
    }
    .stats .n small {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--ink-soft);
      font-weight: 500;
    }
    .stats .label {
      font-family: var(--mono);
      font-size: 9.5px;
      letter-spacing: .12em;
      text-transform: uppercase;
      margin-top: 8px;
      color: var(--ink-soft);
      line-height: 1.35;
    }

    /* ============ SECTION HEADERS ============ */
    .sec-head { padding: 22px 18px 6px; }
    .sec-head .sh-top {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 12px;
      margin-bottom: 6px;
    }
    .sec-head .ch {
      font-family: var(--serif);
      font-weight: 900;
      font-size: 11.5px;
      letter-spacing: .22em;
      color: var(--ink-soft);
      white-space: nowrap;
    }
    .sec-head h3 {
      font-family: var(--display);
      font-size: 38px;
      line-height: .92;
      margin: 0;
      letter-spacing: -.01em;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: clip;
    }
    .sec-head .meta {
      font-family: var(--mono);
      font-size: 9px;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: var(--ink-soft);
      text-align: right;
      line-height: 1.5;
      flex-shrink: 0;
      max-width: 38%;
    }
    .sec-head .meta .verm { color: var(--vermillion-d); font-weight: 700; }
    .sec-rule { margin: 0 18px; border-top: 1.5px solid var(--ink); }

    /* ============ FEATURED COVER ============ */
    .featured-wrap { padding: 14px 18px 6px; }
    .featured {
      position: relative;
      display: flex;
      flex-direction: column;
      aspect-ratio: 4 / 5;
      padding: 18px 20px 18px;
      border: 2.5px solid var(--ink);
      background: var(--oxblood);
      color: var(--paper);
      text-decoration: none;
      overflow: hidden;
      box-shadow: 5px 5px 0 var(--ink);
    }
    .featured .halftone-bg {
      position: absolute;
      inset: 0;
      opacity: .22;
      background-image: radial-gradient(currentColor 1.4px, transparent 1.8px);
      background-size: 9px 9px;
      pointer-events: none;
    }
    .featured .feat-head {
      position: relative;
      z-index: 1;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      font-family: var(--mono);
      font-size: 9px;
      letter-spacing: .16em;
      text-transform: uppercase;
      margin-bottom: 18px;
    }
    .featured .pill {
      background: var(--paper);
      color: var(--ink);
      border: 1.4px solid var(--ink);
      font-size: 9px;
      padding: 3px 7px 2px;
      white-space: nowrap;
    }
    .featured .feat-title {
      position: relative;
      z-index: 1;
      font-family: var(--display);
      font-size: 44px;
      line-height: .88;
      letter-spacing: -.012em;
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .featured .feat-title .ch {
      display: block;
      font-family: var(--serif);
      font-weight: 900;
      font-size: 12px;
      letter-spacing: .18em;
      margin-bottom: 14px;
      opacity: .88;
    }
    .featured .feat-foot {
      position: relative;
      z-index: 1;
      margin-top: 14px;
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: end;
      gap: 14px;
    }
    .featured .feat-foot .blurb {
      font-family: var(--serif);
      font-size: 12.5px;
      line-height: 1.45;
      word-break: keep-all;
      text-wrap: pretty;
    }
    .featured .feat-foot .no {
      font-family: var(--display);
      font-size: 38px;
      line-height: .85;
      align-self: end;
    }

    /* ============ MAGAZINE RACK ============ */
    .rack-scroll {
      margin-top: 8px;
      overflow-x: auto;
      overflow-y: hidden;
      -webkit-overflow-scrolling: touch;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      padding: 14px 18px 22px;
    }
    .rack-scroll::-webkit-scrollbar { display: none; }
    .rack {
      display: flex;
      gap: 14px;
      width: max-content;
    }
    .rack-card {
      flex: 0 0 220px;
      scroll-snap-align: start;
      text-decoration: none;
      color: var(--ink);
      border: 2px solid var(--ink);
      background: var(--paper);
      display: flex;
      flex-direction: column;
      box-shadow: 4px 4px 0 var(--ink);
      transition: transform .15s;
    }
    .rack-card:active { transform: translate(2px, 2px); box-shadow: 2px 2px 0 var(--ink); }
    .rack-cover {
      aspect-ratio: 4 / 5;
      position: relative;
      padding: 16px 14px 14px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      border-bottom: 2px solid var(--ink);
    }
    .rack-cover .halftone-bg {
      position: absolute; inset: 0;
      opacity: .22;
      background-image: radial-gradient(currentColor 1.2px, transparent 1.6px);
      background-size: 7px 7px;
      pointer-events: none;
    }
    .rack-cover .cv-head {
      position: relative; z-index: 1;
      font-family: var(--mono);
      font-size: 8.5px;
      letter-spacing: .16em;
      text-transform: uppercase;
      opacity: .9;
    }
    .rack-cover .cv-title {
      position: relative; z-index: 1;
      font-family: var(--display);
      font-size: 30px;
      line-height: .9;
      letter-spacing: -.005em;
      word-break: keep-all;
      overflow-wrap: break-word;
    }
    .rack-cover .cv-title .ch {
      display: block;
      font-family: var(--serif);
      font-weight: 900;
      font-size: 10px;
      letter-spacing: .18em;
      margin-bottom: 6px;
      opacity: .88;
    }
    .rack-cover .cv-foot {
      position: relative; z-index: 1;
      display: flex;
      justify-content: space-between;
      align-items: end;
      font-family: var(--mono);
      font-size: 8.5px;
      letter-spacing: .14em;
      text-transform: uppercase;
    }
    .rack-cover .cv-foot .no {
      font-family: var(--display);
      font-size: 26px;
      line-height: .9;
    }
    .rack-meta {
      padding: 10px 12px 11px;
      background: var(--paper);
      flex: 1;
      display: flex;
