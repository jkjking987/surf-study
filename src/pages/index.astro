<script is:inline>
  // Dynamic time stamp for the cover scene
  (function tick(){
    const el = document.getElementById('scene-time');
    if(!el) return;
    const update = () => {
      const d = new Date();
      let h = d.getHours(), m = d.getMinutes();
      const ampm = h >= 12 ? 'PM' : 'AM';
      h = h % 12 || 12;
      el.textContent = `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')} ${ampm}`;
    };
    update();
    setInterval(update, 30 * 1000);
  })();

  // Mouse-driven 3D parallax on cover scene
  (function parallax(){
    const scene = document.querySelector('.surf-scene');
    if(!scene) return;
    let targetX = 0, targetY = 0, currentX = 0, currentY = 0;
    let raf = null;
    function loop(){
      currentX += (targetX - currentX) * 0.08;
      currentY += (targetY - currentY) * 0.08;
      scene.style.setProperty('--mx', currentX.toFixed(3));
      scene.style.setProperty('--my', currentY.toFixed(3));
      if(Math.abs(targetX - currentX) > 0.002 || Math.abs(targetY - currentY) > 0.002){
        raf = requestAnimationFrame(loop);
      } else {
        raf = null;
      }
    }
    function onMove(e){
      const r = scene.getBoundingClientRect();
      const cx = (e.clientX - r.left) / r.width;
      const cy = (e.clientY - r.top) / r.height;
      targetX = Math.max(-1, Math.min(1, (cx - 0.5) * 2));
      targetY = Math.max(-1, Math.min(1, (cy - 0.5) * 2));
      if(!raf) raf = requestAnimationFrame(loop);
    }
    function onLeave(){
      targetX = 0; targetY = 0;
      if(!raf) raf = requestAnimationFrame(loop);
    }
    function onTouch(e){
      if(e.touches.length === 0) return;
      const t = e.touches[0];
      const r = scene.getBoundingClientRect();
      const cx = (t.clientX - r.left) / r.width;
      const cy = (t.clientY - r.top) / r.height;
      targetX = Math.max(-1, Math.min(1, (cx - 0.5) * 2));
      targetY = Math.max(-1, Math.min(1, (cy - 0.5) * 2));
      if(!raf) raf = requestAnimationFrame(loop);
    }
    scene.addEventListener('mousemove', onMove);
    scene.addEventListener('mouseleave', onLeave);
    scene.addEventListener('touchmove', onTouch, { passive: true });
    scene.addEventListener('touchend', onLeave);

    // Subtle ambient drift even when mouse is idle, so it feels alive
    let t = 0;
    setInterval(() => {
      if(scene.matches(':hover')) return;
      t += 0.04;
      targetX = Math.sin(t * 0.7) * 0.18;
      targetY = Math.cos(t * 0.5) * 0.12;
      if(!raf) raf = requestAnimationFrame(loop);
    }, 80);
  })();

  // Surf-trick cycle: cycles through CUT BACK / TOP TURN / 360° AIR / BARREL
  (function tricks(){
    const scene = document.querySelector('.surf-scene');
    const label = document.getElementById('trick-name');
    const wrap = scene?.querySelector('.scene-trick');
    if(!scene || !label) return;
    const cycle = [
      { id: 'cutback',  name: 'CUT BACK',  hold: 3700 },
      { id: 'topturn',  name: 'TOP TURN',  hold: 3700 },
      { id: 'three60',  name: '360° AIR',  hold: 3300 }
    ];
    let i = 0;
    function next(){
      const t = cycle[i % cycle.length];
      scene.dataset.trick = t.id;
      // Flip label with a brief transition
      if(wrap){
        wrap.classList.add('flip');
        setTimeout(() => {
          label.textContent = t.name;
          wrap.classList.remove('flip');
        }, 220);
      } else {
        label.textContent = t.name;
      }
      i++;
      setTimeout(next, t.hold);
    }
    // Start at cutback immediately
    scene.dataset.trick = 'cutback';
    label.textContent = 'CUT BACK';
    setTimeout(next, 3700);
  })();
</script>

