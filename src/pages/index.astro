---
import Base from '../layouts/Base.astro';
---

<Base title="衝浪研究室 · THE SURF STUDY">
  <Fragment slot="head">
<style>
  body { overflow-x: hidden; }
  .page {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0 28px 80px;
  }

  /* ===== Masthead ===== */
  .top-strip {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    padding: 10px 0;
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: .14em;
    text-transform: uppercase;
    border-bottom: 1.5px solid var(--ink);
  }
  .top-strip > div { display: flex; gap: 14px; flex-wrap: wrap; align-items: center; }
  .top-strip .blink { color: var(--vermillion); font-weight: 700; }

  .masthead {
    padding: 26px 0 18px;
    border-bottom: 4px double var(--ink);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: end;
    gap: 28px;
  }
  .masthead h1 {
    font-family: var(--display);
    font-size: clamp(72px, 13vw, 196px);
    line-height: .82;
    margin: 0;
    letter-spacing: -.01em;
    grid-column: 1 / -1;
    text-align: center;
    font-feature-settings: "liga";
  }
  .masthead h1 .ch {
    font-family: var(--serif);
    font-weight: 900;
    font-size: .42em;
    letter-spacing: .12em;
    display: block;
    margin-top: 6px;
  }
  .mast-side {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: .12em;
    text-transform: uppercase;
    line-height: 1.55;
  }
  .mast-side.left { text-align: left; }
  .mast-side.right { text-align: right; }

  /* ===== 3D Surf Scene (cover banner) ===== */
  .surf-scene {
    position: relative;
    height: 400px;
    overflow: hidden;
    border-bottom: 1.5px solid var(--ink);
    perspective: 1200px;
    perspective-origin: 50% 60%;
    background: linear-gradient(180deg,
      oklch(0.84 0.08 65) 0%,
      oklch(0.78 0.13 50) 28%,
      oklch(0.70 0.13 38) 48%,
      oklch(0.50 0.13 230) 62%,
      oklch(0.36 0.11 235) 100%);
    cursor: grab;
    --mx: 0;
    --my: 0;
  }
  .surf-scene:active { cursor: grabbing; }
  .surf-scene .stage {
    position: absolute;
    inset: 0;
    transform-style: preserve-3d;
    transform: rotateX(calc(8deg - var(--my) * 6deg)) rotateY(calc(var(--mx) * 8deg));
    transition: transform .25s cubic-bezier(.2,.7,.2,1);
  }
  .surf-scene .sun {
    position: absolute;
    top: 16%;
    left: 50%;
    transform: translate(calc(-50% + var(--mx) * -40px), calc(-50% + var(--my) * -8px)) translateZ(-380px);
    width: 140px;
    height: 140px;
    border-radius: 50%;
    background: radial-gradient(circle,
      oklch(0.96 0.05 80) 0%,
      oklch(0.92 0.12 70) 38%,
      oklch(0.78 0.18 50) 62%,
      transparent 75%);
    filter: blur(.5px);
    animation: sun-pulse 6s ease-in-out infinite;
  }
  .surf-scene .sun::after {
    content: "";
    position: absolute;
    inset: -80px;
    border-radius: 50%;
    background: radial-gradient(circle, oklch(0.92 0.13 60 / .28) 0%, transparent 65%);
    animation: sun-pulse 6s ease-in-out infinite reverse;
  }
  @keyframes sun-pulse {
    0%, 100% { filter: blur(.5px) brightness(1); }
    50% { filter: blur(0px) brightness(1.08); }
  }

  /* Distant headland silhouette */
  .surf-scene .headland {
    position: absolute;
    bottom: 44%;
    left: -8%;
    width: 36%;
    height: 16%;
    background: oklch(0.22 0.05 245 / .85);
    transform: translate(calc(var(--mx) * -16px), 0) translateZ(-260px);
    clip-path: polygon(0 100%, 4% 60%, 12% 78%, 22% 30%, 38% 65%, 52% 45%, 68% 70%, 82% 55%, 100% 80%, 100% 100%);
  }
  .surf-scene .headland.right {
    left: auto;
    right: -8%;
    width: 30%;
    bottom: 42%;
    height: 14%;
    background: oklch(0.18 0.05 245 / .88);
    transform: translate(calc(var(--mx) * -14px), 0) translateZ(-260px);
    clip-path: polygon(0 80%, 14% 60%, 30% 75%, 46% 40%, 60% 65%, 72% 50%, 88% 70%, 100% 90%, 100% 100%, 0 100%);
  }

  /* Ocean horizon */
  .surf-scene .horizon {
    position: absolute;
    bottom: 44%;
    left: 0; right: 0;
    height: 1px;
    background: oklch(0.78 0.08 220 / .55);
    box-shadow: 0 0 8px oklch(0.92 0.10 60 / .45);
    transform: translateZ(-300px);
  }

  /* Wave layers — bigger, more dramatic */
  .surf-scene .wave-layer {
    position: absolute;
    left: -50%;
    width: 200%;
    overflow: visible;
  }
  .surf-scene .wave-layer svg {
    width: 100%;
    height: 100%;
    display: block;
  }
  .surf-scene .wave-back {
    bottom: 36%;
    height: 18%;
    --z: -180px;
    transform: translateZ(-180px) translate(calc(var(--mx) * -22px), 0);
    animation: wave-drift-back 22s linear infinite;
    opacity: .82;
  }
  .surf-scene .wave-mid {
    bottom: 22%;
    height: 28%;
    --z: -60px;
    transform: translateZ(-60px) translate(calc(var(--mx) * -36px), 0);
    animation: wave-drift-mid 13s linear infinite reverse;
  }
  .surf-scene .wave-front {
    bottom: 0;
    height: 70%;
    --z: 80px;
    transform: translateZ(80px) translate(calc(var(--mx) * -60px), calc(var(--my) * 8px));
    animation: wave-drift-front 8s linear infinite;
  }
  @keyframes wave-drift-back {
    0%   { background-position: 0 0; }
    100% { background-position: 600px 0; }
  }
  @keyframes wave-drift-mid {
    0%   { transform: translateZ(-60px) translate(calc(var(--mx) * -36px - 0px), 0); }
    100% { transform: translateZ(-60px) translate(calc(var(--mx) * -36px - 300px), 0); }
  }
  @keyframes wave-drift-front {
    0%   { transform: translateZ(80px) translate(calc(var(--mx) * -60px - 0px), calc(var(--my) * 8px)); }
    100% { transform: translateZ(80px) translate(calc(var(--mx) * -60px - 400px), calc(var(--my) * 8px)); }
  }
  /* Keep back wave drifting too */
  .surf-scene .wave-back {
    animation: wave-drift-back-pos 22s linear infinite;
  }
  @keyframes wave-drift-back-pos {
    0%   { transform: translateZ(-180px) translate(calc(var(--mx) * -22px - 0px), 0); }
    100% { transform: translateZ(-180px) translate(calc(var(--mx) * -22px - 200px), 0); }
  }

  /* Foam at crests */
  .surf-scene .foam {
    position: absolute;
    width: 200%;
    left: -50%;
    bottom: 33%;
    height: 2px;
    background: repeating-linear-gradient(90deg,
      transparent 0, transparent 18px,
      oklch(0.97 0.03 60 / .8) 18px, oklch(0.97 0.03 60 / .8) 28px,
      transparent 28px, transparent 60px);
    transform: translateZ(-50px);
    animation: foam-drift 8s linear infinite;
    opacity: .7;
  }
  @keyframes foam-drift {
    0% { transform: translateZ(-50px) translateX(0); }
    100% { transform: translateZ(-50px) translateX(-15%); }
  }

  /* Surfer silhouette - articulated body parts */
  .surf-scene .surfer {
    position: absolute;
    bottom: 36%;
    left: 50%;
    width: 110px;
    height: 140px;
    transform: translateX(calc(-50% + var(--mx) * 100px)) translateY(calc(var(--my) * -10px)) translateZ(160px);
    filter: drop-shadow(0 12px 12px rgba(26,22,20,.45));
    transition: filter .4s ease;
  }
  .surf-scene .surfer-inner {
    width: 100%;
    height: 100%;
    transform-origin: 50% 90%;
    animation: trick-cutback 3.6s cubic-bezier(.5,.05,.35,1) infinite;
  }
  .surf-scene .surfer svg { width: 100%; height: 100%; display: block; }

  /* Articulated body part groups (animate independently) */
  .surf-scene .surfer .g-arm-lead,
  .surf-scene .surfer .g-arm-trail,
  .surf-scene .surfer .g-torso,
  .surf-scene .surfer .g-legs,
  .surf-scene .surfer .g-head,
  .surf-scene .surfer .g-board {
    transform-box: fill-box;
    transform-origin: center;
  }
  .surf-scene .surfer .g-arm-lead  { transform-origin: 48% 30%; }
  .surf-scene .surfer .g-arm-trail { transform-origin: 52% 30%; }
  .surf-scene .surfer .g-torso     { transform-origin: 50% 80%; }
  .surf-scene .surfer .g-legs      { transform-origin: 50% 20%; }
  .surf-scene .surfer .g-head      { transform-origin: 50% 80%; }
  .surf-scene .surfer .g-board     { transform-origin: 50% 50%; }

  /* Trick cycle */
  .surf-scene[data-trick="cutback"]  .surfer-inner { animation-name: trick-cutback;  animation-duration: 3.6s; }
  .surf-scene[data-trick="topturn"]  .surfer-inner { animation-name: trick-topturn;  animation-duration: 3.6s; }
  .surf-scene[data-trick="three60"]  .surfer-inner { animation-name: trick-three60;  animation-duration: 3.2s; }

  @keyframes trick-cutback {
    0%   { translate: -110% 0; rotate: -18deg; }
    35%  { translate: 70% -6px; rotate: 26deg; }
    70%  { translate: -20% -4px; rotate: -8deg; }
    100% { translate: -110% 0; rotate: -18deg; }
  }
  @keyframes trick-topturn {
    0%   { translate: -30% 8px; rotate: -14deg; }
    35%  { translate: 30% -44px; rotate: 36deg; }
    55%  { translate: 50% -18px; rotate: 12deg; }
    100% { translate: -30% 8px; rotate: -14deg; }
  }
  @keyframes trick-three60 {
    0%   { translate: -40% 0; rotate: -8deg; }
    20%  { translate: 0 -42px; rotate: 30deg; }
    50%  { translate: 30% -28px; rotate: 200deg; }
    75%  { translate: 50% -8px; rotate: 360deg; }
    100% { translate: -40% 0; rotate: 354deg; }
  }

  /* Body-part animations per trick (run in parallel with the trick-* keyframes) */
  .surf-scene[data-trick="cutback"] .g-arm-lead  { animation: arm-lead-cutback 3.6s ease-in-out infinite; }
  .surf-scene[data-trick="cutback"] .g-arm-trail { animation: arm-trail-cutback 3.6s ease-in-out infinite; }
  .surf-scene[data-trick="cutback"] .g-torso     { animation: torso-cutback 3.6s ease-in-out infinite; }
  .surf-scene[data-trick="cutback"] .g-head      { animation: head-bob 3.6s ease-in-out infinite; }

  .surf-scene[data-trick="topturn"] .g-arm-lead  { animation: arm-lead-topturn 3.6s ease-in-out infinite; }
  .surf-scene[data-trick="topturn"] .g-arm-trail { animation: arm-trail-topturn 3.6s ease-in-out infinite; }
  .surf-scene[data-trick="topturn"] .g-legs      { animation: legs-crouch 3.6s ease-in-out infinite; }
  .surf-scene[data-trick="topturn"] .g-torso     { animation: torso-topturn 3.6s ease-in-out infinite; }

  .surf-scene[data-trick="three60"] .g-arm-lead  { animation: arm-tuck 3.2s ease-in-out infinite; }
  .surf-scene[data-trick="three60"] .g-arm-trail { animation: arm-tuck 3.2s ease-in-out infinite; }
  .surf-scene[data-trick="three60"] .g-legs      { animation: legs-air 3.2s ease-in-out infinite; }
  .surf-scene[data-trick="three60"] .g-board     { animation: board-air 3.2s ease-in-out infinite; }

  @keyframes arm-lead-cutback {
    0%, 100% { transform: rotate(-8deg); }
    35%      { transform: rotate(-45deg) translate(-3px, -2px); }
    70%      { transform: rotate(10deg); }
  }
  @keyframes arm-trail-cutback {
    0%, 100% { transform: rotate(8deg); }
    35%      { transform: rotate(35deg) translate(2px, 1px); }
    70%      { transform: rotate(-10deg); }
  }
  @keyframes torso-cutback {
    0%, 100% { transform: rotate(-2deg) translateY(0); }
    35%      { transform: rotate(8deg) translateY(-2px); }
    70%      { transform: rotate(-4deg); }
  }
  @keyframes head-bob {
    0%, 100% { transform: translateY(0); }
    35%      { transform: translateY(-2px); }
    70%      { transform: translateY(1px); }
  }

  @keyframes arm-lead-topturn {
    0%, 100% { transform: rotate(0deg); }
    35%      { transform: rotate(-55deg) translate(-2px, -3px); }
    55%      { transform: rotate(-20deg); }
  }
  @keyframes arm-trail-topturn {
    0%, 100% { transform: rotate(0deg); }
    35%      { transform: rotate(45deg) translate(2px, 0); }
    55%      { transform: rotate(20deg); }
  }
  @keyframes legs-crouch {
    0%, 100% { transform: scaleY(1) translateY(0); }
    35%      { transform: scaleY(.8) translateY(2px); }
    55%      { transform: scaleY(.95); }
  }
  @keyframes torso-topturn {
    0%, 100% { transform: rotate(-4deg); }
    35%      { transform: rotate(18deg) translateY(-2px); }
    55%      { transform: rotate(6deg); }
  }

  @keyframes arm-tuck {
    0%, 100% { transform: rotate(0deg) scale(1); }
    50%      { transform: rotate(-25deg) scale(.85) translate(-3px, 2px); }
  }
  @keyframes legs-air {
    0%, 100% { transform: scaleY(1); }
    30%      { transform: scaleY(.7) translateY(3px); }
    60%      { transform: scaleY(.95); }
  }
  @keyframes board-air {
    0%, 100% { transform: rotate(0); }
    30%      { transform: rotate(-12deg); }
    60%      { transform: rotate(8deg); }
  }

  /* (Barrel removed — only CUT BACK / TOP TURN / 360° AIR cycle) */

  /* Splash particles */
  .surf-scene .splash {
    position: absolute;
    bottom: 34%;
    left: 50%;
    width: 140px;
    height: 60px;
    transform: translateX(calc(-50% + var(--mx) * 40px)) translateZ(60px);
    pointer-events: none;
  }
  .surf-scene .splash i {
    position: absolute;
    width: 3px; height: 3px;
    background: oklch(0.97 0.02 220);
    border-radius: 50%;
    opacity: 0;
    animation: splash-dot 1.2s ease-out infinite;
  }
  .surf-scene .splash i:nth-child(1) { left: 8%;  animation-delay: 0s; }
  .surf-scene .splash i:nth-child(2) { left: 26%; animation-delay: .15s; width: 4px; height: 4px; }
  .surf-scene .splash i:nth-child(3) { left: 44%; animation-delay: .3s; }
  .surf-scene .splash i:nth-child(4) { left: 62%; animation-delay: .5s; width: 5px; height: 5px; }
  .surf-scene .splash i:nth-child(5) { left: 80%; animation-delay: .7s; }
  .surf-scene .splash i:nth-child(6) { left: 16%; animation-delay: .9s; width: 4px; height: 4px; bottom: 12px; }
  .surf-scene .splash i:nth-child(7) { left: 72%; animation-delay: 1.05s; bottom: 18px; }
  @keyframes splash-dot {
    0% { opacity: 0; transform: translateY(0) scale(.4); }
    20% { opacity: .9; }
    100% { opacity: 0; transform: translateY(-32px) scale(1.3); }
  }

  /* Bird specks */
  .surf-scene .bird {
    position: absolute;
    top: 28%;
    width: 14px;
    height: 6px;
    transform: translateZ(-340px);
    color: oklch(0.20 0.04 245 / .8);
    animation: bird-fly 22s linear infinite;
  }
  .surf-scene .bird::before,
  .surf-scene .bird::after {
    content: "";
    position: absolute;
    width: 6px; height: 1.4px;
    background: currentColor;
    border-radius: 50%;
    top: 50%;
  }
  .surf-scene .bird::before { left: 0; transform: rotate(20deg); }
  .surf-scene .bird::after { right: 0; transform: rotate(-20deg); }
  .surf-scene .bird:nth-child(odd) { top: 22%; animation-duration: 26s; }
  @keyframes bird-fly {
    0% { left: -10%; }
    100% { left: 110%; }
  }

  .surf-scene .grain {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(26,22,20,.18) 1px, transparent 1.4px);
    background-size: 4px 4px;
    mix-blend-mode: multiply;
    opacity: .35;
    pointer-events: none;
  }

  .surf-scene .scene-id {
    position: absolute;
    bottom: 8px;
    right: 12px;
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: oklch(0.95 0.02 60 / .65);
    z-index: 10;
  }
  .surf-scene .scene-id span { color: oklch(0.92 0.12 60 / .9); }

  /* Trick label */
  .surf-scene .scene-trick {
    position: absolute;
    top: 12px;
    left: 14px;
    font-family: var(--mono);
    z-index: 10;
    color: oklch(0.98 0.02 60);
    text-shadow: 0 1px 4px rgba(0,0,0,.6);
  }
  .surf-scene .scene-trick small {
    display: block;
    font-size: 9px;
    letter-spacing: .18em;
    text-transform: uppercase;
    opacity: .75;
    color: oklch(0.94 0.10 60);
    margin-bottom: 2px;
  }
  .surf-scene .scene-trick strong {
    display: block;
    font-family: var(--display);
    font-weight: 400;
    font-size: 28px;
    letter-spacing: .04em;
    line-height: 1;
    transition: opacity .25s ease, transform .35s cubic-bezier(.2,.7,.2,1);
  }
  .surf-scene .scene-trick.flip strong {
    opacity: 0;
    transform: translateY(-6px) rotateX(-25deg);
  }

  .surf-scene .scene-hint {
    position: absolute;
    bottom: 8px;
    left: 12px;
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: oklch(0.95 0.02 60 / .55);
    z-index: 10;
    pointer-events: none;
  }

  @media (max-width: 700px) {
    .surf-scene { height: 220px; }
    .surf-scene .sun { width: 100px; height: 100px; top: 18%; }
    .surf-scene .surfer { width: 70px; height: 90px; }
    .surf-scene .scene-hint { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .surf-scene .wave-back,
    .surf-scene .wave-mid,
    .surf-scene .wave-front,
    .surf-scene .surfer,
    .surf-scene .sun,
    .surf-scene .foam,
    .surf-scene .splash i,
    .surf-scene .bird { animation: none; }
    .surf-scene .stage { transition: none; }
  }

  /* tagline strip */
  .tagline-strip {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 9px 4px;
    border-bottom: 1.5px solid var(--ink);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: .14em;
    text-transform: uppercase;
  }
  .tagline-strip .center {
    font-family: var(--display-3);
    font-size: 13px;
    letter-spacing: .14em;
  }

  /* ===== Hero / Editor's note ===== */
  .editors {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    gap: 36px;
    padding: 36px 0 28px;
    border-bottom: 1.5px solid var(--ink);
  }
  .lead-h {
    font-family: var(--display-2);
    font-style: italic;
    font-size: clamp(34px, 4.2vw, 56px);
    line-height: 1.08;
    margin: 0 0 14px;
    color: var(--ocean);
  }
  .lead-h em { color: var(--vermillion); font-style: italic; }
  .lead-body {
    font-family: var(--serif);
    font-size: 16.5px;
    line-height: 1.7;
    column-count: 1;
  }
  .lead-body p { margin: 0 0 12px; }
  .lead-body p::first-letter {}
  .lead-body p:first-child::first-letter {
    font-family: var(--display);
    font-size: 4.2em;
    float: left;
    line-height: .82;
    padding: 6px 8px 0 0;
    color: var(--vermillion);
  }

  .editors-aside {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .stat-block {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border: 1.6px solid var(--ink);
  }
  .stat {
    padding: 14px 14px 12px;
    border-right: 1.5px solid var(--ink);
    border-bottom: 1.5px solid var(--ink);
  }
  .stat:nth-child(2n) { border-right: 0; }
  .stat:nth-last-child(-n+2) { border-bottom: 0; }
  .stat .n {
    font-family: var(--display);
    font-size: clamp(34px, 3.4vw, 48px);
    line-height: .9;
    color: var(--vermillion);
    overflow-wrap: anywhere;
  }
  .stat .label {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: .1em;
    text-transform: uppercase;
    margin-top: 4px;
    color: var(--ink-soft);
  }

  .ticker {
    background: var(--ink);
    color: var(--paper);
    padding: 8px 12px;
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: .14em;
    text-transform: uppercase;
    overflow: hidden;
    white-space: nowrap;
    display: flex;
    gap: 28px;
  }
  .ticker .dot { color: var(--vermillion); }

  /* ===== Issues ===== */
  .issues-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 30px 0 14px;
  }
  .issues-head h2 {
    font-family: var(--display);
    font-size: 56px;
    margin: 0;
    line-height: .9;
  }
  .issues-head .sub {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: .14em;
    text-transform: uppercase;
  }

  .issues {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
    padding-top: 12px;
  }
  @media (max-width: 1280px) {
    .issues { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 800px) {
    .issues { grid-template-columns: minmax(0, 1fr); }
